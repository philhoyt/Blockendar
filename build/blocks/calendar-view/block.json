{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockendar/calendar-view",
  "version": "0.2.0",
  "title": "Event Calendar",
  "category": "blockendar",
  "icon": "calendar-alt",
  "description": "Interactive FullCalendar view. Fetches events from the Blockendar REST API.",
  "keywords": [
    "events",
    "calendar",
    "schedule"
  ],
  "textdomain": "blockendar",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "interactivity": true
  },
  "attributes": {
    "venueId": {
      "type": "integer"
    },
    "typeId": {
      "type": "integer"
    },
    "featuredOnly": {
      "type": "boolean",
      "default": false
    },
    "enabledViews": {
      "type": "array",
      "default": [
        "dayGridMonth",
        "timeGridWeek",
        "timeGridDay",
        "listNextMonth"
      ],
      "items": {
        "type": "string"
      }
    },
    "defaultView": {
      "type": "string",
      "default": "dayGridMonth"
    },
    "firstDay": {
      "type": "integer",
      "default": 0
    }
  },
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css"
}
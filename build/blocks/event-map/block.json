{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockendar/event-map",
  "version": "0.2.0",
  "title": "Event Map",
  "category": "blockendar",
  "icon": "location-alt",
  "description": "Embeds a map at the venue's coordinates. Provider configured in plugin settings.",
  "textdomain": "blockendar",
  "usesContext": [
    "postId",
    "postType"
  ],
  "supports": {
    "html": false
  },
  "attributes": {
    "height": {
      "type": "integer",
      "default": 400
    },
    "zoom": {
      "type": "integer",
      "default": 14
    }
  },
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js"
}
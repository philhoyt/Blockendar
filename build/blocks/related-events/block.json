{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockendar/related-events",
  "version": "0.2.0",
  "title": "Related Events",
  "category": "blockendar",
  "icon": "networking",
  "description": "Shows upcoming events sharing the same type or venue.",
  "textdomain": "blockendar",
  "usesContext": [
    "postId",
    "postType"
  ],
  "supports": {
    "html": false
  },
  "attributes": {
    "maxEvents": {
      "type": "integer",
      "default": 3
    },
    "matchBy": {
      "type": "string",
      "default": "type",
      "enum": [
        "type",
        "venue",
        "both"
      ]
    }
  },
  "render": "file:./render.php",
  "editorScript": "file:./index.js"
}
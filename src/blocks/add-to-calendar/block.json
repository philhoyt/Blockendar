{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/add-to-calendar",
	"version": "0.10.0",
	"title": "Add to Calendar",
	"category": "blockendar",
	"icon": "calendar",
	"description": "Generates add-to-calendar links: Google, Apple, Outlook, and .ics download.",
	"keywords": [ "calendar", "ics", "subscribe" ],
	"textdomain": "blockendar",
	"usesContext": [
		"postId",
		"postType"
	],
	"supports": {
		"html": false,
		"color": {
			"text": true,
			"background": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalWritingMode": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"attributes": {
		"label": {
			"type": "string",
			"default": ""
		},
		"showGoogle": {
			"type": "boolean",
			"default": true
		},
		"showIcal": {
			"type": "boolean",
			"default": true
		},
		"showOutlook365": {
			"type": "boolean",
			"default": true
		},
		"showOutlookLive": {
			"type": "boolean",
			"default": true
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}

{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/calendar-view",
	"version": "0.9.3",
	"title": "Event Calendar",
	"category": "blockendar",
	"icon": "calendar-alt",
	"description": "Interactive FullCalendar view. Fetches events from the Blockendar REST API.",
	"keywords": [ "events", "calendar", "schedule" ],
	"textdomain": "blockendar",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"venueIds":      { "type": "array", "default": [], "items": { "type": "integer" } },
		"typeIds":       { "type": "array", "default": [], "items": { "type": "integer" } },
		"featuredOnly":  { "type": "boolean", "default": false },
		"enabledViews":  {
			"type": "array",
			"default": [ "dayGridMonth", "timeGridWeek", "timeGridDay", "listNextMonth" ],
			"items": { "type": "string" }
		},
		"defaultView":   { "type": "string", "default": "dayGridMonth" },
		"firstDay":      { "type": "integer", "default": 0 }
	},
	"render":       "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css",
	"viewScript":   "file:./view.js",
	"style":        "file:./style-index.css"
}

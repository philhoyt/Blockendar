{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/event-countdown",
	"version": "0.9.3",
	"title": "Event Countdown",
	"category": "blockendar",
	"icon": "backup",
	"description": "Live countdown timer to event start. Updates client-side.",
	"textdomain": "blockendar",
	"usesContext": [ "postId", "postType" ],
	"supports": { "html": false },
	"attributes": {
		"expiredLabel": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"viewScript":   "file:./view.js"
}

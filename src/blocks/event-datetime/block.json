{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/event-datetime",
	"version": "0.9.2",
	"title": "Event Date & Time",
	"category": "blockendar",
	"icon": "clock",
	"description": "Displays formatted start and end date/time with timezone.",
	"textdomain": "blockendar",
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"color": {
			"text": true,
			"background": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalWritingMode": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"dimensions": {
			"minHeight": true
		}
	},
	"attributes": {
		"showStartDate": { "type": "boolean", "default": true },
		"showStartTime": { "type": "boolean", "default": true },
		"showEndDate":   { "type": "boolean", "default": true },
		"showEndTime":   { "type": "boolean", "default": true },
		"showTimezone":  { "type": "boolean", "default": false }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}

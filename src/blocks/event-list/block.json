{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/event-list",
	"version": "0.9.1",
	"title": "Event List",
	"category": "blockendar",
	"icon": "list-view",
	"description": "A filterable list of upcoming or past events. Server-side rendered.",
	"keywords": [ "events", "list", "upcoming" ],
	"textdomain": "blockendar",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"usesContext": [],
	"attributes": {
		"venueId":      { "type": "integer" },
		"typeId":       { "type": "integer" },
		"featuredOnly": { "type": "boolean", "default": false },
		"showPast":     { "type": "boolean", "default": false },
		"perPage":      { "type": "integer", "default": 10 },
		"layout":       { "type": "string",  "default": "list",   "enum": [ "list", "grid" ] },
		"groupBy":      { "type": "string",  "default": "none",   "enum": [ "none", "date", "month", "type" ] },
		"pagination":   { "type": "string",  "default": "paged",  "enum": [ "paged", "load_more" ] },
		"orderby":      { "type": "string",  "default": "start_datetime" },
		"order":        { "type": "string",  "default": "ASC" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style":        "file:./style-index.css"
}

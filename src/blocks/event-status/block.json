{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/event-status",
	"version": "0.9.2",
	"title": "Event Status Badge",
	"category": "blockendar",
	"icon": "flag",
	"description": "Shows a styled status badge (Cancelled, Postponed, Sold Out). Hidden for scheduled events.",
	"textdomain": "blockendar",
	"usesContext": [
		"postId",
		"postType"
	],
	"supports": {
		"html": false,
		"color": {
			"text": true,
			"background": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"textAlign": true,
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalWritingMode": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"attributes": {},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}

{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/events-query",
	"version": "0.9.6",
	"title": "Events Query",
	"category": "blockendar",
	"icon": "calendar-alt",
	"description": "Queries upcoming events and renders each one using the inner block template.",
	"keywords": [ "events", "query", "list", "loop" ],
	"textdomain": "blockendar",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"blockGap": true,
			"__experimentalDefaultControls": {
				"blockGap": true
			}
		}
	},
	"usesContext": [ "postId", "postType" ],
	"attributes": {
		"typeIds":       { "type": "array",   "default": [], "items": { "type": "integer" } },
		"perPage":       { "type": "integer", "default": 10 },
		"showPast":      { "type": "boolean", "default": false },
		"order":         { "type": "string",  "default": "ASC" },
		"inherit":          { "type": "boolean", "default": false },
		"showPagination":   { "type": "boolean", "default": true },
		"relatedTo":     { "type": "string",  "default": "none", "enum": [ "none", "type", "venue", "both" ] },
		"displayLayout": {
			"type": "object",
			"default": { "type": "list" }
		}
	},
	"render":       "file:./render.php",
	"editorScript": "file:./index.js",
	"style":        "file:./style-index.css"
}

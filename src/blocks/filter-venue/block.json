{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockendar/filter-venue",
	"version": "0.9.5",
	"title": "Filter by Venue",
	"category": "blockendar",
	"icon": "location",
	"description": "Lets visitors filter an Events Query block by venue.",
	"keywords": [ "events", "filter", "venue", "location" ],
	"textdomain": "blockendar",
	"parent": [ "blockendar/query-filters" ],
	"supports": {
		"html": false,
		"spacing": { "margin": true, "padding": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"usesContext": [ "blockendar/queryId" ],
	"attributes": {
		"displayStyle":  { "type": "string",  "default": "list", "enum": [ "list", "dropdown" ] },
		"showEmpty":     { "type": "boolean", "default": false },
		"showVirtual":   { "type": "boolean", "default": true },
		"label":         { "type": "string",  "default": "" }
	},
	"render":       "file:./render.php",
	"editorScript": "file:./index.js",
	"viewScript":   "file:./view.js",
	"style":        "file:./style-index.css"
}
